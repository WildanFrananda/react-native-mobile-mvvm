{
  "name": "react-native-mobile-mvvm",
  "version": "0.8.8",
  "description": "MVVM Architecture Standard for React Native — Compose/Flutter DX (ViewModel, StateFlow, DI)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./di": {
      "types": "./dist/di/index.d.ts",
      "import": "./dist/di/index.mjs",
      "require": "./dist/di/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "react-native",
    "mvvm",
    "viewmodel",
    "stateflow",
    "rxjs",
    "dependency-injection",
    "compose",
    "flutter",
    "architecture",
    "state-management",
    "tsyringe"
  ],
  "author": "Wildan Frananda <wildanrailfanskrl@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WildanFrananda/react-native-mobile-mvvm.git"
  },
  "bugs": {
    "url": "https://github.com/WildanFrananda/react-native-mobile-mvvm/issues"
  },
  "homepage": "https://github.com/WildanFrananda/react-native-mobile-mvvm#readme",
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.71",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "tsyringe": "^4"
  },
  "devDependencies": {
    "@swc/core": "^1.15.33",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-native": "^0.85.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "tsyringe": "^4.10.0",
    "typescript": "^6.0.3"
  }
}