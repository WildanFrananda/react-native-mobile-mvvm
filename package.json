{
  "name": "react-native-mobile-mvvm",
  "version": "0.7.0",
  "description": "MVVM Architecture Standard for React Native — Compose/Flutter DX (ViewModel, StateFlow, DI)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./di": {
      "types": "./dist/di/index.d.ts",
      "import": "./dist/di/index.mjs",
      "require": "./dist/di/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "jest"
  },
  "keywords": [
    "react-native",
    "mvvm",
    "viewmodel",
    "stateflow",
    "rxjs",
    "dependency-injection",
    "compose",
    "flutter",
    "architecture",
    "state-management",
    "tsyringe"
  ],
  "author": "Wildan Frananda <wildanrailfanskrl@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.71",
    "rxjs": "^7",
    "tsyringe": "^4",
    "reflect-metadata": "^0.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.72.8",
    "react": "^19.2.6",
    "react-native": "^0.85.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsup": "^8.5.1",
    "tsyringe": "^4.10.0",
    "typescript": "^6.0.3"
  }
}
